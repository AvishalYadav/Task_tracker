# ===========================================================================
#  HOW TO USE THIS FILE
#  - Commit THIS .example file to GitHub (it has no real secrets).
#  - Locally: copy it to  .streamlit/secrets.toml  (drop ".example") and fill in.
#  - NEVER commit the real .streamlit/secrets.toml (the .gitignore blocks it).
# ===========================================================================

# 1) App login password — used BOTH locally and on Community Cloud.
app_password = "change-me-to-a-strong-password"

# ===========================================================================
# 2) Google service-account credentials.
#    LOCAL:           NOT required — the app reads your curious-drive-*.json
#                     key file directly from disk.
#    COMMUNITY CLOUD: REQUIRED — there is no .json file up there, so uncomment
#                     the block below and paste each value from your JSON key.
#                     Keep private_key exactly as in the JSON (\n sequences intact).
# ===========================================================================
# [gcp_service_account]
# type = "service_account"
# project_id = "curious-drive-471111-v1"
# private_key_id = "PASTE_FROM_JSON"
# private_key = "-----BEGIN PRIVATE KEY-----\nPASTE_KEY_WITH_\\n_INTACT\n-----END PRIVATE KEY-----\n"
# client_email = "your-sa@curious-drive-471111-v1.iam.gserviceaccount.com"
# client_id = "PASTE_FROM_JSON"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "PASTE_FROM_JSON"
